{
    "name": "cubicltd/laravel-boost-kilo",
    "description": "Laravel Boost extension package that provides Kilo Code IDE integration",
    "keywords": [
        "laravel",
        "boost",
        "kilo",
        "kilo-cli",
        "kilo-code",
        "ide",
        "ai",
        "development"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Cubic Ltd",
            "homepage": "https://cubic.ltd"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.47.0|^12.53.0|^13.0",
        "laravel/boost": "^2.3.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.9.3",
        "laravel/pint": "^1.28.0",
        "laravel/sail": "^1.53",
        "orchestra/testbench": "^9.16.0|^10.9.0|^11.0",
        "pestphp/pest": "^2.36.1|^3.8.5|^4.4.2",
        "rector/rector": "^2.3.8"
    },
    "autoload": {
        "psr-4": {
            "CubicLtd\\LaravelBoostKilo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CubicLtd\\LaravelBoostKilo\\KiloServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": [
            "pint",
            "vendor/bin/phpstan analyse",
            "rector"
        ],
        "test": "pest",
        "test:lint": [
            "pint --test",
            "rector --dry-run"
        ],
        "test:types": "vendor/bin/phpstan analyse",
        "check": [
            "@composer lint",
            "@composer test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
